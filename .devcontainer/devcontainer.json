{
  "name": "muscle-tracker",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 3001, 3306],
  "mounts": [
    "source=${localEnv:HOME}/workspace/projects/dotfiles,target=/root/dotfiles,type=bind,consistency=cached"
  ],
  "postCreateCommand": "bash /root/dotfiles/setup.sh; cd /workspace/backend && bundle install && cd /workspace/frontend && npm install",
  "remoteEnv": {
    "SHELL": "/usr/bin/zsh"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[ruby]": {
          "editor.defaultFormatter": "Shopify.ruby-lsp"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        }
      }
    }
  }
}
